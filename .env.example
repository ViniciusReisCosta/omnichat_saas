# CberHunt environment example
# Copy this file to .env for local development.
# In Railway, configure these values in the service Variables panel.

# The frontend calls the NestJS backend through NEXT_PUBLIC_API_URL.
# Local Postgres config belongs to D:\nodeprojects\omnichat_backend.

# Required only for legacy Next API/Prisma scripts that still exist in this project.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/db-omnichat?schema=public"

# Auth/session secret. Generate a long random string for production.
JWT_SECRET=CHANGE_ME_long_random_jwt_secret

# Application origin. In production set both to your final HTTPS domain.
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Stripe billing. Required only when checkout/webhook billing is enabled.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_ENTERPRISE=
