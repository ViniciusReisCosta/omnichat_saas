# CberHunt environment example
# Copy this file to .env for local development.
# In Railway, configure these values in the service Variables panel.

# Local Docker/Postgres values used by docker-compose.yml.
POSTGRES_USER=omniconnect
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=omniconnect

# Prisma database URL.
# Local Docker Desktop:
DATABASE_URL="postgresql://omniconnect:CHANGE_ME_strong_db_password@127.0.0.1:5432/omniconnect?schema=public"
#
# Railway Postgres:
# DATABASE_URL="${{Postgres.DATABASE_URL}}"

# Auth/session secret. Generate a long random string for production.
JWT_SECRET=CHANGE_ME_long_random_jwt_secret

# Application origin. In production set both to your final HTTPS domain.
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe billing. Required only when checkout/webhook billing is enabled.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_ENTERPRISE=

# pgAdmin values used only by docker-compose local/VPS setups.
PGADMIN_DEFAULT_EMAIL=admin@local.test
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME_pgadmin_password
