# ──────────────────────────────────────────────────────────────────────────
# CberHunt — production environment
# Copy this file to ".env" on the server and fill in REAL secrets.
#   cp .env.example .env && nano .env
# This single file is read by BOTH docker compose (Postgres/pgAdmin) and Next.js.
# Never commit the real .env (it is git-ignored).
# ──────────────────────────────────────────────────────────────────────────

# --- PostgreSQL (used by docker-compose) ---
POSTGRES_USER=omniconnect
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=omniconnect

# --- Next.js app (Prisma) ---
# Host is 127.0.0.1 because Postgres is published on localhost and the app runs via pm2 on the host.
# Must match POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB above.
DATABASE_URL="postgresql://omniconnect:CHANGE_ME_strong_db_password@127.0.0.1:5432/omniconnect?schema=public"

# Long random string. Generate with:  openssl rand -base64 48
JWT_SECRET=CHANGE_ME_long_random_jwt_secret

NODE_ENV=production

# --- pgAdmin (used by docker-compose) ---
# This email + password is your pgAdmin LOGIN at https://pgadmin.cbersoftware.com.br
PGADMIN_DEFAULT_EMAIL=admin@cbersoftware.com.br
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME_pgadmin_password
